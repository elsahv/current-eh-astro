---
import TestMarkdownHeader from "../components/tests/TestMarkdownHeader.astro";
import MainLayout from "./MainLayout.astro";

const { frontmatter } = Astro.props;
---

<MainLayout>
  <TestMarkdownHeader />
  <div id="markdown-post" class="text-lg 2xl:p-5">
    <div
      id="right-side-markdown-container"
      class="border-l border-onyx h-screen md:absolute relative right-0 md:w-4/5 w-full overflow-y-scroll overflow-x-hidden 2xl:p-5 md:p-3"
    >
      <section class="bg- 2xl:p-5 p-2 md:mx-5 mx-1">
        <div class="bg- flex 2xl:flex-row flex-col-reverse">
          <img
            src={frontmatter.image.url}
            alt=""
            class="w-[1100px] drop-shadow-md border border-gray-300 rounded mt-3"
          />
          <div class="mt-5 pt-5 2xl:pl-4">
            <h1 class="text-4xl font-">{frontmatter.title}</h1>
            <p class="pt-1 pr-2 md:pl-1 text-lg">
              {frontmatter.testItem1}
            </p>
            <div class="text-gray-600 pl-1 hover:underline">
              <a href={frontmatter.websiteUrl}> view website</a>
            </div>
          </div>
        </div>
        <div id="website-content" class="pl-5 2xl:w-3/4 pt-4 dropshadow-3xl">
          <h2 class="text-3xl text-onyx font-">Project journal</h2>

          <div class="pt-2 opacity-80 text-lg">
            {frontmatter.testItem1}
            <slot />
          </div>
        </div>
      </section>
    </div>
  </div>
</MainLayout>
