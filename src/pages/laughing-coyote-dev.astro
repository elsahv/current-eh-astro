---
import MainLayout from "../layouts/MainLayout.astro";
import TestMarkdownHeader from "../components/tests/TestMarkdownHeader.astro";
import ServicePackages from "../components/tests/ServicePackages.astro";
import CustomDigitalArtistry from "../components/tests/CustomDigitalArtistry.astro";
---

<MainLayout>
  <TestMarkdownHeader />
  <div
    id="right-side-markdown-container"
    class="bg- border-l border-onyx md:h-screen h-full md:absolute relative right-0 md:w-4/5 w-full overflow-y-scroll overflow-x-hidden 2xl:p-5 md:p-3 md:ml-[50px] pl-[50px]"
  >
    <div
      id="work-with-me"
      class="bg- pt-2 md:pl-5 2xl:px-3 my-5 2xl:mr-[130px] 2xl:pr-5 bg-"
    >
      <div id="padding" class="bg- 2xl:p-5 p-2 md:mx-5 mx-1">
        <h1 id="work-with-me-title" class="2xl:text-4xl text-3xl">
          About Laughing Coyote Dev
        </h1>

        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!--TODO: productDef="LC-What is the product, service, or idea you're promoting?" -->
        <section class="bg-test1" id="PRODUCT DEFINITION">
          <h2>PRODUCT DEFINITION</h2>
          <p class="">
            1st paragraph, elaborate and explanation of lc/ Core Idea: Position
            your service as a digital atelier—a creative studio where your
            clients' visions are translated into vivid, handcrafted websites.
            Think of each site as a collaborative artwork: your client brings
            the inspiration, and you bring the technical brushstrokes "What
            separates web developers from Ai? Human innovation!
          </p>
        </section>
        <img
          src="https://dl.dropboxusercontent.com/scl/fi/36vnm2e663uln6akmex4d/lc.png?rlkey=lgim54nbp0u11mviylee29hyj&st=1nuybim1&dl=0"
          alt=""
          class="border border-gray-300 my-2"
        />
        <!-- TODO: targetAudience="Who is your target audience?" -->
        <section class="bg-test2" id="TARGET AUDIENCE">
          <h2>TARGET AUDIENCE</h2>
          <p class="bg-orange">
            Unique Selling Point: You're not just designing websites—you’re
            co-creating digital homes for passionate people. You get their
            creative process because you share it.
          </p>
        </section>

        <!-- TODO: mainGoal=" What is the main goal of the campaign? (e.g. brand awareness, sales, community building)" -->
        <section class="bg-test1" id="MAIN GOAL OF SITE">
          <h2>MAIN GOAL OF SITE"</h2>
        </section>

        <!-- TODO: audienceMessage="What feeling or message do you want the audience to take away?" -->
        <section class="bg-test2" id="AUDIENCE MESSAGE">
          <h2>AUDIENCE MESSAGE</h2>
          <ul
            class="bg-test1"
            id="audience message: to feel good about having a site that displays their own messages"
          >
            <h2>Visual/Brand Mood:</h2>
            <li>Cozy, colorful, and whimsical</li>
            <li>Hand-drawn elements, textured backgrounds, natural shapes</li>
            <li>Soft, custom typography and pastel palettes</li>
          </ul>
        </section>

        <!-- TODO: keyFeatures=" Are there any key features, benefits, or values that should be highlighted?" -->
        <section class="bg-test2" id="KEY FEATURES">
          <h2>key features</h2>

          <ul class="bg-orange">
            <h2>Key Features/Offers:</h2>
            <li>
              Portfolio-First Design: Build sites that feel like immersive
              galleries or journals.
            </li>
            <li>
              Storytelling Frameworks: Let creatives tell their brand story
              visually and emotionally.
            </li>
            <li>
              Creative Companion Calls: A process that feels more like an artist
              collaboration than a business transaction.
            </li>
            <li>
              “Palette Picker” Questionnaire: Help clients choose colors based
              on their work and style.
            </li>
          </ul>
        </section>

        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->
        <!-- *^ -->

        <ul>
          <h2>Visual Style & Design Elements Think “boho meets browser”:</h2>
          <li>
            Color Palette: Muted earth tones, vintage pastels, and rich accent
            colors (like ochre, dusty rose, sage, ink blue)
          </li>
          <li>Textures: Paper grain, watercolor washes, layered collages</li>
          <li>
            Typography: Soft serif headlines (like Cormorant Garamond or
            Playfair) + friendly sans-serifs (like Quicksand or DM Sans)
          </li>
          <li>
            Illustration Style: Sketchy icons, line drawings of tools
            (paintbrushes, cameras, books, etc.), dotted borders and torn edges
          </li>
          <li>
            Microinteractions: Hover animations like brush strokes appearing,
            cursor turning into a paintbrush, loading screens with small “art
            studio” metaphors
          </li>
        </ul>

        <div class="bg- mt-[50px]">
          <div class="">
            <ul class="bg-">
              <h2>Mockup Ideas</h2>
              <h3>You can create concept mockups like:</h3>
              <li>
                The Painters Portfolio A homepage that mimics a physical
                sketchbook or gallery wall. Scrolling feels like flipping pages.
              </li>
              <li>
                The Storytellers Scroll A long-form landing page styled like a
                storybook—each section is a “chapter” in the brand’s journey.
              </li>
              <li>
                The Makers Bench A grid-style site that looks like a workspace,
                with tool icons, sticky notes, and pinned inspirations alongside
                project work.
              </li>
            </ul>

            <p class="">
              This content bridges the gap between the featured img and 'website
              concepts'
            </p>
          </div>
          <div id="TEST-grid-wrapper" class="bg- my-5 py-5 mt-5 pr-3">
            <div id="TEST-grid" class="grid grid-cols-2 gap-10 mt-5">
              <img
                src="https://dl.dropboxusercontent.com/scl/fi/g23z3n6u9joennznyqxc4/lc-9-20-24.png?rlkey=q75joo6od6ixkfoxr9q57kfkb&st=19kz2kwm&dl=0"
                alt=""
                class="border border-gray-400 h-[350px] w-full"
              />

              <img
                src="https://images.pexels.com/photos/304664/pexels-photo-304664.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
                alt=""
                class="border border-gray-400 h-[350px] w-full"
              />

              <img
                src="https://dl.dropboxusercontent.com/scl/fi/r2memu9vr71tw03oe57kz/IMG_0300.jpg?rlkey=k9upvwvx4vudmyv88f8srhxlu&st=g5s7cqo5&dl=0"
                alt=""
                class="border border-gray-400 h-[350px] w-full"
              />

              <img
                src="https://images.pexels.com/photos/2893525/pexels-photo-2893525.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
                alt=""
                class="border border-gray-400 h-[350px] w-full"
              />
            </div>
          </div>

          <p class="2xl:pt-2 pt-3 2xl:px-5">
            "What separates web developers from Ai? Human innovation! how this
            site helps client with their business. Lorem ipsum dolor sit, amet
            consectetur adipisicing elit. Alias atque dolor quis eveniet tempore
            rem laborum omnis quisquam quasi eaque modi, facere officiis quae
            maiores. Libero nesciunt sit adipisci sapiente iste error officia
            mollitia illum, hic facilis consequatur veniam! Hic reiciendis sunt
            nulla tempora unde.
          </p>
        </div>
      </div>

      <ServicePackages />
      <CustomDigitalArtistry />
    </div>
  </div>
</MainLayout>
