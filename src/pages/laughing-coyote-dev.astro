          <h2>AUDIENCE MESSAGE</h2>
          <ul
            class="bg-"
            id="audience message: to feel good about having a site that displays their own messages"
          >
            <h2>Visual/Brand Mood:</h2>
            <li>Cozy, colorful, and whimsical</li>
            <li>Hand-drawn elements, textured backgrounds, natural shapes</li>
            <li>Soft, custom typography and pastel palettes</li>
          </ul>
        </section>
