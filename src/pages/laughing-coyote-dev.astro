        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->
        <!-- *v -->

        <!-- !ALL THE REST vvv   -->
        <!-- TODO: targetAudience="Who is your target audience?"v -->
        <section class="py-3" id="TARGET AUDIENCE">
          <h2>TARGET AUDIENCE</h2>
          <p>The people I'm looking to serve...</p>
          <p class="bg-">
            Unique Selling Point: You're not just designing websites—you’re
            co-creating digital homes for passionate people. You get their
            creative process because you share it.
          </p>
        </section>

        <!-- TODO: mainGoal=" What is the main goal of the campaign? (e.g. brand awareness, sales, community building)" v-->
        <section
          class="my-5 border border-black px-3 py-5"
          id="MAIN GOAL OF SITE"
        >
          <h2>MAIN GOAL OF SITE"</h2>
          <CustomDigitalArtistry />
        </section>

        <!-- TODO: keyFeatures=" Are there any key features, benefits, or values that should be highlighted?" v-->
