---
import MainLayout from "../layouts/MainLayout.astro";
import SiteCard from "../components/SiteCard.astro";
import Contact from "../components/sections/Contact.astro";
const allFeaturedSites = await Astro.glob("./creative-concepts/*.md");
import FeaturedWorkCTA from "../components/sections/FeaturedWorkCTA.jsx";
import LeftSidebar from "../components/LeftSidebar.astro";
---

<MainLayout>
  <div id="flex" class="flex lg:flex-row flex-col">
    <LeftSidebar />

    <div
      id="RIGHT-SIDE"
      class="font-medium border-l border-onyx 2xl:h-screen h-full md:absolute relative right-0 sm:bottom md:w-3/5 w-full md:overflow-y-scroll overflow-x-hidden xl:p-5"
    >
      <div id="" class="bg- px-5">
        <FeaturedWorkCTA />
        <div id="creative-concepts" class="bg- mr-2 mt-[155px] md:px-5">
          <h1 class="font- 2xl:text-4xl text-3xl">Creative Concepts</h1>
          <p id="services" class="bg- p-1">
            There are my projects in progress. In the rest of my free time, I
            enjoy building these out with javascript frameworks or php
            wordpress. I've built these three sites to not only categorize and
            simplify my life, but to be creative too! So far, I've built...
          </p>
          <div id="grid" class="pl-1 pr-3 grid 2xl:grid-cols-2 gap-12">
            {
              allFeaturedSites.map((work) => (
                <SiteCard
                  title={work.frontmatter.title}
                  image={work.frontmatter.image.url}
                  alt={work.frontmatter.image.alt}
                  url={work.url}
                  testItem1={work.frontmatter.testItem1}
                />
              ))
            }
          </div>
        </div>

        <div
          id="rightside-conditional-contact-wrapper"
          class="2xl:invisible visible"
        >
          <Contact />
        </div>
      </div>
    </div>
  </div>
</MainLayout>
